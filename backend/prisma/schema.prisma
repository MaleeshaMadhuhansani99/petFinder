

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User{
  id        String @id @default(uuid())
  email     String @unique
  name      String
  address   String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pets      Pet[]
}

model Pet{
  id        String @id @default(uuid())
  colour    String
  breed     String
  species   String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User    @relation(fields: [id], references: [id])
}

